# =============================================================================
# DataScout Agent — Environment Variables
# =============================================================================
# Copy this file to .env and replace the placeholder values with your real keys.
# NEVER commit your .env file to version control.
# =============================================================================

# Google AI / Gemini API key (used for LLM calls)
GOOGLE_API_KEY=your-google-api-key-here

# Kaggle API credentials
# Option 1: Set these environment variables directly.
# Option 2: Place your kaggle.json at ~/.kaggle/kaggle.json (takes precedence).
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key-here
